NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# Supabase Auth — dipakai khusus oleh halaman Reset Password untuk membaca
# session recovery dari link email dan memanggil supabase.auth.updateUser().
# Nilai ini aman dipublikasikan ke browser (anon key memang didesain publik).
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
